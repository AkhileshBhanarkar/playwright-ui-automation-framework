{
  "name": "playwright-automation",
  "version": "1.0.0",
  "description": "Playwright automation framework using JavaScript",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "smoke": "npx playwright test --grep @smoke",
    "regression": "npx playwright test --grep @regression",
    "report": "npx playwright show-report",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "ui-testing",
    "e2e"
  ],
  "author": "Akhilesh Bhanarkar",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.1",
    "dotenv": "^16.3.1",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0"
  }
}